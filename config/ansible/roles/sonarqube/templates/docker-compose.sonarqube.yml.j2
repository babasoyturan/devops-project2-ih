services:
  sonarqube-db:
    image: postgres:15
    container_name: {{ sonarqube_postgres_container_name }}
    restart: unless-stopped
    environment:
      POSTGRES_DB: {{ sonarqube_postgres_db }}
      POSTGRES_USER: {{ sonarqube_postgres_user }}
      POSTGRES_PASSWORD: {{ sonarqube_postgres_password }}
    volumes:
      - sonarqube_db_data:/var/lib/postgresql/data
    networks:
      - sonarqube-net

  sonarqube:
    image: {{ sonarqube_image }}
    container_name: {{ sonarqube_container_name }}
    restart: unless-stopped
    depends_on:
      - sonarqube-db
    ports:
      - "{{ sonarqube_port }}:9000"
    environment:
      SONAR_JDBC_URL: jdbc:postgresql://sonarqube-db:5432/{{ sonarqube_postgres_db }}
      SONAR_JDBC_USERNAME: {{ sonarqube_postgres_user }}
      SONAR_JDBC_PASSWORD: {{ sonarqube_postgres_password }}
    volumes:
      - sonarqube_data:/opt/sonarqube/data
      - sonarqube_logs:/opt/sonarqube/logs
      - sonarqube_extensions:/opt/sonarqube/extensions
      - sonarqube_temp:/opt/sonarqube/temp
    tmpfs:
      - /tmp:size=256M,mode=1777
    networks:
      - sonarqube-net

volumes:
  sonarqube_db_data:
  sonarqube_data:
  sonarqube_logs:
  sonarqube_extensions:
  sonarqube_temp:

networks:
  sonarqube-net:
    driver: bridge
