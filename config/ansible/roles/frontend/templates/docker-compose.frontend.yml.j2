services:
  frontend:
    image: {{ frontend_image_name }}:{{ frontend_image_tag }}
    container_name: {{ frontend_container_name }}
    restart: unless-stopped
    ports:
      - "{{ frontend_port }}:80"
    environment:
      NODE_ENV: production
      VITE_API_BASE_URL: "{{ frontend_api_base_url | default('/api') }}"
